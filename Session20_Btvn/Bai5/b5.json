{
	"info": {
		"name": "Concert Ticketing System Testing",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Đăng nhập thành công",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.environment.set(\"accessToken\", jsonData.accessToken);",
							"pm.environment.set(\"refreshToken\", jsonData.refreshToken);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"hoan@gmail.com\",\n    \"password\": \"password123\"\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/concert/auth/login",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "concert", "auth", "login"]
				}
			},
			"response": []
		},
		{
			"name": "2. Xem danh mục vé đang mở bán",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/concert/tickets/available",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "concert", "tickets", "available"]
				}
			},
			"response": []
		},
		{
			"name": "3. Chốt đơn thành công (Mock QR OK)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"items\": [\n        {\n            \"ticketCategoryId\": 1,\n            \"quantity\": 2\n        }\n    ]\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/concert/bookings/checkout",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "concert", "bookings", "checkout"]
				}
			},
			"response": []
		},
		{
			"name": "4. Kiểm tra Fallback khi lỗi Feign (Chỉnh URL lỗi trên PartnerMockController hoặc đổi config của api.qr-service.url sang port chết rồi request lại)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"items\": [\n        {\n            \"ticketCategoryId\": 2,\n            \"quantity\": 1\n        }\n    ]\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/concert/bookings/checkout",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "concert", "bookings", "checkout"]
				}
			},
			"response": []
		},
		{
			"name": "5. Đăng xuất",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/concert/auth/logout",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "concert", "auth", "logout"]
				}
			},
			"response": []
		}
	]
}