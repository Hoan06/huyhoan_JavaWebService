{
	"info": {
		"name": "E-Learning Platform System Testing",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Đăng nhập hệ thống",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.environment.set(\"elearning_accessToken\", jsonData.accessToken);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"hoan@gmail.com\",\n    \"password\": \"password123\"\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/elearning/auth/login",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "elearning", "auth", "login"]
				}
			},
			"response": []
		},
		{
			"name": "2. Thống kê tiến độ (Stream API)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{elearning_accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/elearning/study/my-progress",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "elearning", "study", "my-progress"]
				}
			},
			"response": []
		},
		{
			"name": "3. Nhận chứng chỉ thành công (Khóa 1 - Đã học xong)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{elearning_accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/elearning/study/1/claim-certificate",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "elearning", "study", "1", "claim-certificate"]
				}
			},
			"response": []
		},
		{
			"name": "4. Thử nhận chứng chỉ thất bại (Khóa 2 - Chưa học xong)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{elearning_accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/elearning/study/2/claim-certificate",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "elearning", "study", "2", "claim-certificate"]
				}
			},
			"response": []
		},
		{
			"name": "5. Yêu cầu Đăng xuất",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{elearning_accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/elearning/auth/logout",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "elearning", "auth", "logout"]
				}
			},
			"response": []
		}
	]
}